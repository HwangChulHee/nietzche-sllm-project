# =====================
# 예외: 실험 결과 및 로그 (발표/재현용 필수)
# =====================
# Stage B 응답 생성 결과
!ml/finetune/outputs/stage_b/
!ml/finetune/outputs/stage_b/*.jsonl
!ml/finetune/outputs/stage_b/*.json
!ml/finetune/outputs/stage_b_test/
!ml/finetune/outputs/stage_b_test/*.jsonl

# Stage C LLM judge 채점 결과
!ml/finetune/outputs/stage_c/
!ml/finetune/outputs/stage_c/*.jsonl
!ml/finetune/outputs/stage_c/*.json
!ml/finetune/outputs/stage_c/*.md

# Stage B 실행 로그 (수 MB, 디버깅/재현용)
!ml/finetune/logs/
!ml/finetune/logs/*.log
